# Required. Strong random value of at least 24 characters for the Bearer
# token that authenticates /api/* and /mcp*.
# Generate with e.g. `openssl rand -base64 32` or `uuidgen`.
# Well-known placeholder values (dev-token-change-me, test-token, etc.) are
# rejected at runtime — the worker returns 503 until a strong value is set.
# The Deploy to Cloudflare button prompts for this value during setup.
API_TOKEN=replace-with-output-of-openssl-rand-base64-32

# Optional: Analytics Engine SQL query credentials.
# CF_ACCOUNT_ID=your-cloudflare-account-id
# CF_ANALYTICS_TOKEN=your-cloudflare-api-token-with-account-analytics-read

# Optional: comma-separated origin allowlist for CORS. Unset or `*` leaves
# every origin allowed (safe because the API is bearer-auth only). Set to a
# specific origin list when you publish a UI.
# CORS_ALLOW_ORIGIN=https://ui.example.com,https://admin.example.com

# Optional: canonical origin used in `shortUrl` responses and for edge cache
# purges. When the worker is bound to a custom domain, set this to the
# short-link host so responses don't echo the request host.
# PUBLIC_BASE_URL=https://go.example.com

# Optional: host split. When both are set, the redirect host refuses
# /api/* and /mcp/* traffic, and the API host refuses /:slug traffic.
# REDIRECT_HOST=go.example.com
# API_HOST=api.example.com
